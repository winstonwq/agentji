# agentji environment variables
# Copy this file to .env and fill in your values.
# agentji reads secrets from the environment — never hardcode keys in agentji.yaml.

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Alibaba DashScope (Qwen) ─────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-...

# ── Moonshot (Kimi) ──────────────────────────────────────────────────────────
MOONSHOT_API_KEY=sk-...

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (local) ───────────────────────────────────────────────────────────
# No API key needed. Set base_url in agentji.yaml:
#   base_url: http://localhost:11434
# OLLAMA_API_BASE=http://localhost:11434

# ── Network / Proxy (WSL2 users) ─────────────────────────────────────────────
# If API calls fail in WSL2, set your proxy:
# https_proxy=http://127.0.0.1:7890
# http_proxy=http://127.0.0.1:7890
